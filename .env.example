# ============================================================================
# Lane E Daily Control Report — environment variables
# Copy to .env.local and fill in. NEVER commit .env.local.
# ============================================================================

# --- Supabase -------------------------------------------------------------
# Project URL is public; the service-role key is SECRET (server-only, never
# exposed to the browser). The dashboard is fully server-rendered, so the
# browser never needs a Supabase client.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Google service account (read-only Sheets access) ---------------------
# Create a service account, enable the Google Sheets API, download the JSON key.
# Share every one of the 12 spreadsheets (see config/sheet-mapping.ts) with
# GOOGLE_SERVICE_ACCOUNT_EMAIL as Viewer, or the API returns 403.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the private key WITH literal \n sequences (as it appears in the JSON).
# The code does .replace(/\\n/g, '\n') — see lib/sync/google-auth.ts and
# BUILD_NOTES.md ("invalid_grant" gotcha).
GOOGLE_PRIVATE_KEY=

# --- Cron protection ------------------------------------------------------
# Long random string. /api/cron/sync rejects any request lacking it.
# Vercel cron sends it as `Authorization: Bearer <CRON_SECRET>`.
# External schedulers can pass `?secret=<CRON_SECRET>`.
CRON_SECRET=

# --- Dashboard auth (the password gate) -----------------------------------
# Admin/manager password (full access — create/update/approve/delete).
DASHBOARD_PASSWORD=
# Optional viewer password (read-only): the CEO + project coordinator can
# navigate everything and open evidence, but cannot edit/approve/delete/ingest.
# Leave blank to disable the viewer-password login.
VIEWER_PASSWORD=
# Optional private "share link" token (read-only, NO password to type). Anyone
# who opens  https://<site>/impact?access=<VIEWER_LINK_TOKEN>  is granted a viewer
# session, then the token is stripped from the URL (so it isn't left in the bar /
# history). For the CEO + coordinator to review by clicking a bookmarked link.
# Use a long random string; rotate or revoke by changing/clearing this value.
# Leave blank to disable the link.
VIEWER_LINK_TOKEN=
# Secret used to sign the auth session cookie (HMAC). Long random string.
AUTH_SESSION_SECRET=

# --- Impact tab (Tab 2) — Claude extraction -------------------------------
# Server-side only. Powers the /api/ingest extraction step (model
# claude-sonnet-4-6) that turns a pasted report / uploaded document into a
# REVIEW PROPOSAL. If unset, ingestion still works: the raw upload is stored
# and the review screen shows a "extraction skipped" note — nothing is ever
# written to projects/tasks without an explicit Approve. Zoho imports and all
# manual CRUD do not need this key.
ANTHROPIC_API_KEY=
