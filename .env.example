# ============================================================================
# Lane E Daily Control Report — environment variables
# Copy to .env.local and fill in. NEVER commit .env.local.
# ============================================================================

# --- Supabase -------------------------------------------------------------
# Project URL is public; the service-role key is SECRET (server-only, never
# exposed to the browser). The dashboard is fully server-rendered, so the
# browser never needs a Supabase client.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Google service account (read-only Sheets access) ---------------------
# Create a service account, enable the Google Sheets API, download the JSON key.
# Share every one of the 12 spreadsheets (see config/sheet-mapping.ts) with
# GOOGLE_SERVICE_ACCOUNT_EMAIL as Viewer, or the API returns 403.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the private key WITH literal \n sequences (as it appears in the JSON).
# The code does .replace(/\\n/g, '\n') — see lib/sync/google-auth.ts and
# BUILD_NOTES.md ("invalid_grant" gotcha).
GOOGLE_PRIVATE_KEY=

# --- Cron protection ------------------------------------------------------
# Long random string. /api/cron/sync rejects any request lacking it.
# Vercel cron sends it as `Authorization: Bearer <CRON_SECRET>`.
# External schedulers can pass `?secret=<CRON_SECRET>`.
CRON_SECRET=

# --- Dashboard auth (the password gate) -----------------------------------
# The single shared password the reviewer enters at /login.
DASHBOARD_PASSWORD=
# Secret used to sign the auth session cookie (HMAC). Long random string.
AUTH_SESSION_SECRET=
